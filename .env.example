# ================= Faktura on Flare — configuration =================
# Copy to .env and fill in. Persona private keys are plain hex files under
# keys/{agent,investor,debtor}.key (see README "Run it"), not env vars.

# ---- Flare Coston2 network ----
COSTON2_RPC_URL=https://coston2-api.flare.network/ext/C/rpc

# ---- Deployed contracts (printed by contracts: npm run deploy:coston2) ----
# Two-address posture:
#   FAKTURA_CONTRACT          = the DEMO hub the interactive service uses
#                               (demo mode may toggle its fdcEnforced flag)
#   FAKTURA_EVIDENCE_CONTRACT = the EVIDENCE hub, permanently strict —
#                               strict runs route here automatically and
#                               demo mode refuses to touch it
FAKTURA_CONTRACT=
FAKTURA_EVIDENCE_CONTRACT=
FAKTURA_FXRP=

# ---- FDC gating ----
# demo   = instant interactive registrations (on-chain fdcEnforced flipped off;
#          facts still ABI-encoded exactly as the Web2Json response delivers them)
# strict = every registration runs a REAL Web2Json attestation and the contract
#          verifies the Merkle proof on-chain (~3-5 min per invoice)
FAKTURA_FDC=demo

# FDC endpoints (testnet defaults; same values as flare-hardhat-starter)
VERIFIER_URL_TESTNET=https://fdc-verifiers-testnet.flare.network
VERIFIER_API_KEY_TESTNET=00000000-0000-0000-0000-000000000000
COSTON2_DA_LAYER_URL=https://ctn2-data-availability.flare.network

# Supplier system-of-record URL template for strict attestations
# ({number} is replaced by the invoice number). Defaults to the repo's
# committed docs/erp exports served via GitHub Pages (the Web2Json verifier
# requires Content-Type application/json — GitHub *raw* URLs do not qualify).
# Point it at your own public /erp/invoices/{number} endpoint when hosting.
# FAKTURA_ERP_URL_TEMPLATE=https://a252937166.github.io/faktura/erp/{number}.json

# ---- LLM underwriter ----
# auto = DEEPSEEK_API_KEY -> ANTHROPIC_API_KEY -> claude CLI -> deterministic mock
LLM_PROVIDER=auto
LLM_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-pro

# ---- Collector agent ----
COLLECTOR_INTERVAL_MS=30000
# short grace so autonomous defaults are demonstrable live (contract redeploys
# read this at deploy time):
FAKTURA_GRACE_SECONDS=120

# ---- x402-inspired risk oracle (price in FLR wei) ----
X402_PRICE_WEI=2000000000000000000

# ---- Hosted read-only showcase (no secret keys on the host) ----
# FAKTURA_SHOWCASE=1
# FAKTURA_SEED=agents/data/seed.json
